---

<section class="map-section">
    <div
        id="eclipse-map"
        class="map-container"
        data-polygon={JSON.stringify(totalityPolygon)}
        data-places={JSON.stringify(data.places)}
    >
    </div>
</section>

<style>
    .map-section {
        margin-top: clamp(3rem, 7vw, 5rem);
    }

    .map-container {
        width: 100%;
        height: 450px;
        border-radius: var(--radius);
        overflow: hidden;
        border: 1px solid var(--line);
        z-index: 1;
        position: relative;
    }

    .map-container :global(.leaflet-container) {
        background: var(--void);
        font-family: var(--font-body);
    }

    .map-container :global(.leaflet-control-zoom a) {
        background: var(--ink-soft);
        color: var(--bone-dim);
        border-color: var(--line);
    }

    .map-container :global(.leaflet-control-zoom a:hover) {
        background: var(--ink);
        color: var(--bone);
    }

    .map-container :global(.leaflet-control-attribution) {
        background: rgba(7, 6, 10, 0.8) !important;
        color: var(--muted-deep);
        font-size: 0.6rem;
    }

    .map-container :global(.leaflet-control-attribution a) {
        color: var(--muted);
    }

    .map-container :global(.leaflet-control-attribution a:hover) {
        color: var(--space-blue);
    }

    .map-container :global(.map-marker) {
        display: flex;
        align-items: center;
        gap: 6px;
        pointer-events: none;
    }

    .map-container :global(.map-marker__dot) {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 2px solid rgba(255, 255, 255, 0.3);
        background: var(--space-blue);
        box-shadow:
            0 0 8px var(--halo),
            0 0 20px var(--halo-soft);
        flex-shrink: 0;
    }

    .map-container :global(.map-marker__dot--edge) {
        background: var(--edge-blue);
        box-shadow: 0 0 6px rgba(46, 107, 158, 0.4);
    }

    .map-container :global(.map-marker__dot--partial) {
        width: 8px;
        height: 8px;
        background: var(--muted-deep);
        border-color: var(--line);
        box-shadow: none;
    }

    .map-container :global(.map-marker__label) {
        background: rgba(7, 6, 10, 0.85);
        border: 1px solid var(--line);
        border-radius: 4px;
        padding: 2px 6px;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--bone-dim);
        white-space: nowrap;
    }

    .map-container :global(.map-marker__label--total) {
        color: var(--space-blue-light);
        border-color: rgba(0, 170, 255, 0.3);
    }

    .map-container :global(.map-marker__label--edge) {
        color: var(--edge-blue);
        border-color: rgba(46, 107, 158, 0.35);
    }

    @media (max-width: 560px) {
        .map-container {
            height: 300px;
        }
    }
</style>

<script>
    import 'leaflet/dist/leaflet.css';
    import L from 'leaflet';

    const container = document.getElementById('eclipse-map');
    if (!container) throw new Error('Map container not found');

    const polygon = JSON.parse(container.dataset.polygon || '[]');
    const places = JSON.parse(container.dataset.places || '[]');

    const map = L.map(container, {
        center: [41.5, -2.5],
        zoom: 7,
        scrollWheelZoom: true,
        zoomControl: true,
    });

    L.Control.Zoom.prototype.options.zoomInTitle = 'Acercar';
    L.Control.Zoom.prototype.options.zoomOutTitle = 'Alejar';

    L.tileLayer(
        'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
        {
            attribution:
                '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> · <a href="https://carto.com/">CARTO</a>',
            subdomains: 'abcd',
            maxZoom: 19,
        },
    ).addTo(map);

    L.polygon(polygon, {
        color: '#00aaff',
        weight: 2,
        opacity: 0.8,
        fillColor: '#00aaff',
        fillOpacity: 0.12,
    }).addTo(map);

    places.forEach((p) => {
        if (!p.lat || !p.lng) return;

        let dotClass = 'map-marker__dot';
        let labelClass = 'map-marker__label';

        if (p.type === 'edge') {
            dotClass += ' map-marker__dot--edge';
            labelClass += ' map-marker__label--edge';
        } else if (p.type === 'partial') {
            dotClass += ' map-marker__dot--partial';
        } else {
            labelClass += ' map-marker__label--total';
        }

        const html = `<span class="${dotClass}"></span><span class="${labelClass}">${p.city}</span>`;

        L.marker([p.lat, p.lng], {
            icon: L.divIcon({
                className: 'map-marker',
                html,
                iconSize: [0, 0],
                iconAnchor: [0, 12],
            }),
        }).addTo(map);
    });
</script>
