---
// EclipseAnimation — pure CSS solar eclipse.
// Moon crosses the Sun; at totality the corona blooms and a
// diamond-ring flashes on each contact. Loops. Respects reduced motion.
---

<figure
    class="eclipse"
    role="img"
    aria-label="Animación de un eclipse solar total: la Luna cruza el Sol y revela la corona."
>
    <div class="stage">
        <div class="corona"></div>
        <div class="chromosphere"></div>
        <div class="sun"></div>
        <div class="moon"></div>
        <div class="diamond"></div>
    </div>
</figure>

<style>
    .eclipse {
        /* Override global blue palette — sun stays gold */
        --space-blue: #f6c453;
        --space-blue-light: #ffe09a;
        --ember: #db7a3c;
        --ember-deep: #a84e23;
        --space-blue-rgb: 246, 196, 83;
        --ember-rgb: 219, 122, 60;
        --halo: rgba(246, 196, 83, 0.55);
        --halo-soft: rgba(246, 196, 83, 0.16);

        margin: 0 auto;
        display: grid;
        place-items: center;
        aspect-ratio: 1;
        width: min(100%, 800px);
        max-width: 100vmin;
        max-height: 50vh;
        box-sizing: border-box;
        padding: clamp(0.55rem, 2.2vw, 1rem);
        overflow: visible;
        contain: layout;
    }

    .stage {
        position: relative;
        width: 100%;
        height: 100%;
        display: grid;
        place-items: center;
        isolation: isolate;
    }

    .stage > * {
        position: absolute;
        inset: 0;
        margin: auto;
        border-radius: 50%;
    }

    /* The solar disc */
    .sun {
        width: 46%;
        aspect-ratio: 1;
        background: radial-gradient(
            circle at 50% 50%,
            var(--space-blue-light) 0%,
            #ffd77a 38%,
            var(--space-blue) 72%,
            #e7b347 100%
        );
        box-shadow:
            0 0 34px 3px var(--halo),
            0 0 68px 10px var(--halo-soft);
        z-index: 1;
    }

    .sun::after {
        content: '';
        position: absolute;
        inset: -18%;
        border-radius: 50%;
        background: radial-gradient(
            circle,
            rgba(var(--space-blue-rgb), 0.42) 0%,
            rgba(var(--space-blue-rgb), 0.16) 36%,
            rgba(var(--space-blue-rgb), 0) 72%
        );
        opacity: 0;
        transform: scale(0.9);
        animation: totality-glow 16s var(--ease) infinite;
        pointer-events: none;
    }

    /* Inner chromosphere ring revealed at totality */
    .chromosphere {
        width: 49%;
        aspect-ratio: 1;
        border: 2px solid rgba(var(--ember-rgb), 0.55);
        opacity: 0;
        transform: scale(0.96);
        z-index: 0;
        animation: none;
    }

    /* The streaming corona — only blooms at totality */
    .corona {
        width: 46%;
        aspect-ratio: 1;
        background: radial-gradient(
            circle,
            transparent 48%,
            var(--halo) 50%,
            rgba(var(--space-blue-rgb), 0.05) 62%,
            transparent 75%
        );
        opacity: 0;
        transform: scale(0.9);
        z-index: 0;
        animation: corona-bloom 16s var(--ease) infinite;
        will-change: transform, opacity;
    }

    /* The Moon — opaque disc that occludes the Sun */
    .moon {
        width: 46.5%;
        aspect-ratio: 1;
        background: radial-gradient(
            circle at 38% 35%,
            #1b1722 0%,
            #0c0a11 60%,
            #060509 100%
        );
        box-shadow: inset -8px -8px 24px rgba(0, 0, 0, 0.7);
        z-index: 2;
        transform: translate3d(-150%, 0, 0);
        animation: transit 16s ease-in-out infinite;
        will-change: transform, opacity;
    }

    /* Diamond-ring flash at second & third contact */
    /* .diamond {
		width: 7%;
		aspect-ratio: 1;
		background: radial-gradient(circle, #fff 0%, var(--space-blue-light) 30%, transparent 70%);
		box-shadow: 0 0 30px 10px var(--space-blue-light);
		opacity: 0;
		z-index: 3;
		transform: translate(-150%, 0);
		animation: diamond 16s linear infinite;
	} */

    @keyframes transit {
        0% {
            opacity: 0;
            transform: translate3d(-150%, 0, 0);
        }
        14% {
            opacity: 1;
        }
        44%,
        56% {
            opacity: 1;
            transform: translate3d(0, 0, 0);
        }
        86% {
            opacity: 1;
        }
        100% {
            opacity: 0;
            transform: translate3d(150%, 0, 0);
        }
    }

    @keyframes corona-bloom {
        0%,
        38% {
            opacity: 0;
            transform: scale(0.85);
        }
        47%,
        53% {
            opacity: 1;
            transform: scale(1.18);
        }
        62%,
        100% {
            opacity: 0;
            transform: scale(0.85);
        }
    }

    @keyframes chromo {
        0%,
        42% {
            opacity: 0;
            transform: scale(0.96);
        }
        48%,
        50% {
            opacity: 1;
            transform: scale(1.01);
        }
        54%,
        100% {
            opacity: 0;
            transform: scale(0.96);
        }
    }

    @keyframes totality-glow {
        0%,
        43% {
            opacity: 0;
            transform: scale(0.9);
        }
        48%,
        52% {
            opacity: 1;
            transform: scale(1.18);
        }
        58%,
        100% {
            opacity: 0;
            transform: scale(0.9);
        }
    }

    /* Diamond rides the moon's leading/trailing edge: bright just
	   before and after totality, dark during.
	   Off-screen during totality to prevent render artifacts. */
    @keyframes diamond {
        0%,
        40% {
            opacity: 0;
            transform: translate(-150%, 0);
        }
        42% {
            opacity: 1;
            transform: translate(-22%, 0);
        }
        44% {
            opacity: 0;
            transform: translate(-150%, 0);
        }
        56% {
            opacity: 0;
            transform: translate(-150%, 0);
        }
        58% {
            opacity: 1;
            transform: translate(22%, 0);
        }
        60%,
        100% {
            opacity: 0;
            transform: translate(150%, 0);
        }
    }

    /* Reduced motion: freeze at the totality moment */
    @media (prefers-reduced-motion: reduce) {
        .moon {
            transform: translateX(0%);
            animation: none;
        }
        .corona {
            opacity: 1;
            transform: scale(1.15);
            animation: none;
        }
        .chromosphere {
            opacity: 0;
            transform: scale(0.96);
            animation: none;
        }
        .sun {
            animation: none;
        }

        .sun::after {
            opacity: 1;
            transform: scale(1.1);
            animation: none;
        }

        .diamond {
            opacity: 0;
            animation: none;
        }
    }

    @media (max-width: 560px) {
        .eclipse {
            width: 100dvw;
            max-width: 100dvw;
            max-height: 42vh;
            margin-inline: calc(50% - 50dvw);
            padding: 0;
            overflow: hidden;
            contain: layout paint;
        }

        .sun {
            background: radial-gradient(
                circle at 50% 50%,
                var(--space-blue-light) 0%,
                #ffd77a 42%,
                var(--space-blue) 78%,
                #f0bf56 100%
            );
            box-shadow:
                0 0 26px 2px var(--halo),
                0 0 48px 7px var(--halo-soft);
        }

        .chromosphere {
            animation: none;
            opacity: 0;
        }
    }
</style>
