---
import event from '../data/event.json';
// Totality begins ~20:30 CEST over the peninsula on the event date.
const target = `${event.date}T20:30:00+02:00`;
---

<section id="cuenta" class="cd">
    <div class="shell cd__shell">
        <span class="eyebrow">Cuenta atrás</span>
        <div
            class="cd__clock"
            data-target={target}
            role="timer"
            aria-live="off"
        >
            <div class="unit">
                <span class="unit__n" data-d>—</span><span class="unit__l"
                    >días</span
                >
            </div>
            <span class="sep">:</span>
            <div class="unit">
                <span class="unit__n" data-h>—</span><span class="unit__l"
                    >horas</span
                >
            </div>
            <span class="sep">:</span>
            <div class="unit">
                <span class="unit__n" data-m>—</span><span class="unit__l"
                    >min</span
                >
            </div>
            <span class="sep">:</span>
            <div class="unit">
                <span class="unit__n" data-s>—</span><span class="unit__l"
                    >seg</span
                >
            </div>
        </div>
        <p class="cd__msg" data-msg>hasta la totalidad sobre España</p>
    </div>
</section>

<style>
    .cd {
        padding-block: var(--section-y);

        position: relative;
        z-index: 1;
        text-align: center;
    }

    .cd__shell {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.8rem;
    }

    .cd__clock {
        display: flex;
        align-items: flex-start;
        gap: clamp(0.5rem, 2vw, 1.6rem);
        font-variant-numeric: tabular-nums;
    }

    .unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: clamp(3.5rem, 11vw, 7rem);
    }

    .unit__n {
        font-family: var(--font-mono);
        font-weight: 200;
        font-size: var(--step-4);
        line-height: 0.9;
        color: var(--bone);
        text-shadow: 0 0 50px var(--halo-soft);
    }

    .unit__l {
        margin-top: 0.6rem;
        font-family: var(--font-mono);
        font-size: 0.66rem;
        text-transform: uppercase;
        letter-spacing: 0.28em;
        color: var(--muted);
    }

    .sep {
        font-family: var(--font-display);
        font-size: var(--step-3);
        line-height: 0.9;
        color: var(--space-blue);
        opacity: 0.5;
    }

    .cd__msg {
        font-family: var(--font-display);
        font-style: italic;
        font-size: var(--step-1);
        color: var(--bone-dim);
    }

    @media (max-width: 560px) {
        .cd__shell {
            width: 100%;
        }

        .cd__clock {
            width: 100%;
            box-sizing: border-box;
            justify-content: center;
            padding-inline: clamp(0.8rem, 4vw, 1.2rem);
        }
    }
</style>

<script>
    function tick() {
        document
            .querySelectorAll<HTMLElement>('.cd__clock')
            .forEach((clock) => {
                const target = new Date(clock.dataset.target!).getTime();
                const diff = target - Date.now();
                const set = (sel: string, v: number) => {
                    const el = clock.querySelector<HTMLElement>(
                        `[data-${sel}]`,
                    );
                    if (el) el.textContent = String(v).padStart(2, '0');
                };

                if (diff <= 0) {
                    set('d', 0);
                    set('h', 0);
                    set('m', 0);
                    set('s', 0);
                    const msg =
                        clock.parentElement?.querySelector<HTMLElement>(
                            '[data-msg]',
                        );
                    if (msg)
                        msg.textContent =
                            'El eclipse ya ha ocurrido. Hasta la próxima sombra.';
                    return;
                }

                const s = Math.floor(diff / 1000);
                set('d', Math.floor(s / 86400));
                set('h', Math.floor((s % 86400) / 3600));
                set('m', Math.floor((s % 3600) / 60));
                set('s', s % 60);
            });
    }

    tick();
    setInterval(tick, 1000);
</script>
