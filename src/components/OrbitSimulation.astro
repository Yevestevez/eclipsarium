---
// OrbitSimulation — top-down orbital view of Sun-Earth-Moon.
// Earth orbits Sun, Moon orbits Earth. Camera zooms in at the
// alignment moment each cycle (Moon passes between Sun and Earth).
---

<figure class="orbit" role="img" aria-label="Vista cenital del sistema Sol-Tierra-Luna: órbitas y alineación durante el eclipse.">
	<div class="o-stage">
		<div class="o-ring"></div>
		<div class="o-sun"></div>
		<div class="o-earth-wrap">
			<div class="o-earth">
				<div class="o-moon-wrap">
					<div class="o-moon"></div>
				</div>
			</div>
		</div>
		<div class="o-beam"></div>
	</div>
</figure>

<style>
	.orbit {
		--sun-gold: #f6c453;
		--sun-hot: #ffe09a;

		margin: 2rem 0 0;
		display: grid;
		place-items: center;
		aspect-ratio: 1;
		width: min(72vmin, 540px);
	}

	.o-stage {
		position: relative;
		width: 100%;
		height: 100%;
		display: grid;
		place-items: center;
		animation: o-zoom 20s var(--ease) infinite;
	}

	/* --- Orbit guide ring --- */
	.o-ring {
		position: absolute;
		width: 72%;
		aspect-ratio: 1;
		border: 1px solid rgba(244, 239, 230, 0.08);
		border-radius: 50%;
		pointer-events: none;
	}

	/* --- Sun --- */
	.o-sun {
		position: absolute;
		width: 16%;
		aspect-ratio: 1;
		border-radius: 50%;
		background: radial-gradient(circle at 50% 50%, var(--sun-hot) 0%, var(--sun-gold) 45%, #db7a3c 88%, #a84e23 100%);
		box-shadow: 0 0 40px 10px rgba(246, 196, 83, 0.5), 0 0 120px 40px rgba(246, 196, 83, 0.15);
		z-index: 3;
	}

	/* --- Earth orbit rotation --- */
	.o-earth-wrap {
		position: absolute;
		width: 72%;
		aspect-ratio: 1;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%) rotate(0deg);
		animation: o-orbit 20s linear infinite;
		z-index: 2;
	}

	/* --- Earth --- */
	.o-earth {
		position: absolute;
		top: 0;
		left: 50%;
		width: 12%;
		aspect-ratio: 1;
		transform: translate(-50%, -50%);
		border-radius: 50%;
		background: radial-gradient(circle at 35% 35%, #5aaeff 0%, #1a4a8a 55%, #0e2a5a 100%);
		box-shadow: 0 0 14px 4px rgba(74, 158, 255, 0.35), inset -4px -4px 12px rgba(0, 0, 0, 0.4);
	}

	/* --- Moon orbit rotation --- */
	.o-moon-wrap {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 260%;
		aspect-ratio: 1;
		transform: translate(-50%, -50%) rotate(180deg);
		animation: o-orbit 10s linear infinite;
		z-index: 1;
	}

	/* --- Moon --- */
	.o-moon {
		position: absolute;
		top: 0;
		left: 50%;
		width: 18%;
		aspect-ratio: 1;
		transform: translate(-50%, -50%);
		border-radius: 50%;
		background: radial-gradient(circle at 38% 35%, #d0d0d0 0%, #909090 50%, #555 100%);
		box-shadow: inset -3px -3px 8px rgba(0, 0, 0, 0.5);
	}

	/* --- Alignment beam --- */
	.o-beam {
		position: absolute;
		width: 3px;
		height: 44%;
		background: linear-gradient(to top, rgba(246, 196, 83, 0.2), transparent);
		transform-origin: bottom center;
		z-index: 1;
		animation: o-beam 20s var(--ease) infinite;
	}

	/* --- Animations --- */
	@keyframes o-orbit {
		to { transform: translate(-50%, -50%) rotate(360deg); }
	}

	@keyframes o-zoom {
		0%, 30% { transform: scale(1); }
		40% { transform: scale(1.4); }
		50% { transform: scale(1.5); }
		60% { transform: scale(1.35); }
		70%, 100% { transform: scale(1); }
	}

	@keyframes o-beam {
		0%, 42% { opacity: 0; transform: translateY(-50%) scaleY(0); }
		48% { opacity: 1; transform: translateY(-50%) scaleY(1); }
		55% { opacity: 0.8; transform: translateY(-50%) scaleY(0.9); }
		62% { opacity: 0; transform: translateY(-50%) scaleY(0); }
		100% { opacity: 0; transform: translateY(-50%) scaleY(0); }
	}

	/* --- Reduced motion --- */
	@media (prefers-reduced-motion: reduce) {
		.o-earth-wrap,
		.o-moon-wrap { animation: none; }
		.o-stage { animation: none; }
		.o-beam { animation: none; opacity: 0; }
	}
</style>
