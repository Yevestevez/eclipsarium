---

<section class="map-section">
    <div
        id="eclipse-map"
        class="map-container"
        data-polygon={JSON.stringify(totalityPolygon)}
        data-places={JSON.stringify(data.places)}
    >
    </div>
</section>

<style>
    .map-section {
        margin-top: clamp(3rem, 7vw, 5rem);
    }

    .map-container {
        width: 100%;
        height: 450px;
        border-radius: var(--radius);
        overflow: hidden;
        border: 1px solid var(--line);
        z-index: 1;
        position: relative;
    }

    .map-container :global(.leaflet-container) {
        background: var(--void);
        font-family: var(--font-body);
    }

    .map-container :global(.leaflet-control-zoom a) {
        background: var(--ink-soft);
        color: var(--bone-dim);
        border-color: var(--line);
    }

    .map-container :global(.leaflet-control-zoom a:hover) {
        background: var(--ink);
        color: var(--bone);
    }

    .map-container :global(.leaflet-control-attribution) {
        background: var(--overlay) !important;
        color: var(--muted-deep);
        font-size: 0.6rem;
    }

    .map-container :global(.leaflet-control-attribution a) {
        color: var(--muted);
    }

    .map-container :global(.leaflet-control-attribution a:hover) {
        color: var(--space-blue);
    }

    .map-container :global(.map-marker) {
        display: flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
    }

    .map-container :global(.map-marker__dot) {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 2px solid var(--line-strong);
        background: var(--space-blue);
        box-shadow:
            0 0 8px var(--halo),
            0 0 20px var(--halo-soft);
        flex-shrink: 0;
        transition:
            transform 0.3s var(--ease),
            box-shadow 0.3s var(--ease);
    }

    .map-container :global(.map-marker:hover .map-marker__dot) {
        transform: scale(1.8);
        box-shadow:
            0 0 16px var(--halo),
            0 0 40px var(--halo-soft);
    }

    .map-container :global(.map-marker__dot--edge) {
        background: var(--edge-blue);
        box-shadow: 0 0 6px rgba(46, 107, 158, 0.4);
    }

    .map-container :global(.map-marker:hover .map-marker__dot--edge) {
        box-shadow: 0 0 14px rgba(46, 107, 158, 0.7);
    }

    .map-container :global(.map-marker__dot--partial) {
        width: 8px;
        height: 8px;
        background: var(--muted-deep);
        border-color: var(--line);
        box-shadow: none;
    }

    .map-container :global(.map-marker:hover .map-marker__dot--partial) {
        width: 12px;
        height: 12px;
        background: var(--muted);
        box-shadow: 0 0 10px rgba(141, 134, 153, 0.4);
    }

    .map-container :global(.map-marker__label) {
        background: var(--overlay);
        border: 1px solid var(--line);
        border-radius: 4px;
        padding: 2px 6px;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--bone-dim);
        white-space: nowrap;
        transition: color 0.3s var(--ease);
    }

    .map-container :global(.map-marker:hover .map-marker__label) {
        color: var(--bone);
    }

    .map-container :global(.map-marker__label--total) {
        color: var(--space-blue-light);
        border-color: rgba(0, 170, 255, 0.3);
    }

    .map-container :global(.map-marker__label--edge) {
        color: var(--edge-blue);
        border-color: rgba(46, 107, 158, 0.35);
    }

    /* --- Marker popup on hover --- */
    .map-container
        :global(.map-marker__popup-wrap .leaflet-popup-content-wrapper) {
        background: var(--ink-soft) !important;
        border: 1px solid var(--line) !important;
        border-radius: var(--radius) !important;
        box-shadow:
            var(--shadow-popup),
            0 0 0 1px rgba(0, 170, 255, 0.08) !important;
        color: var(--bone) !important;
        font-family: var(--font-body);
        padding: 0 !important;
        overflow: hidden;
    }

    .map-container :global(.map-marker__popup-wrap .leaflet-popup-tip) {
        background: var(--ink-soft) !important;
        border: 1px solid var(--line) !important;
        box-shadow: none !important;
    }

    .map-container :global(.map-marker__popup-wrap .leaflet-popup-content) {
        margin: 0;
        padding: 0.9rem 1rem 0.8rem;
        font-family: var(--font-body);
    }

    .map-container :global(.map-marker__popup) {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .map-container :global(.map-marker__popup-tag) {
        font-family: var(--font-mono);
        font-size: 0.55rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        padding: 0.15rem 0.45rem;
        border-radius: 0.15rem;
        align-self: flex-start;
        color: var(--void);
        background: var(--space-blue);
        margin-bottom: 0.3rem;
    }

    .map-container :global(.map-marker__popup-city) {
        font-size: 1rem;
        line-height: 1.2;
        color: var(--bone);
        font-weight: 600;
    }

    .map-container :global(.map-marker__popup-region) {
        font-size: 0.75rem;
        color: var(--muted);
    }

    .map-container :global(.map-marker__popup-meta) {
        display: flex;
        gap: 0.8rem;
        font-family: var(--font-mono);
        font-size: 0.68rem;
        color: var(--bone-dim);
        margin-top: 0.3rem;
    }

    .map-container :global(.map-marker__popup-link) {
        display: inline-block;
        margin-top: 0.4rem;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--space-blue-light);
        text-decoration: none;
        transition: color 0.2s var(--ease);
    }

    .map-container :global(.map-marker__popup-link:hover) {
        color: var(--space-blue);
        text-decoration: underline;
    }

    @media (max-width: 560px) {
        .map-container {
            height: 300px;
        }
    }
</style>

<script>
    import 'leaflet/dist/leaflet.css';
    import L from 'leaflet';

    type MapPlace = {
        city: string;
        region: string;
        slug: string;
        lat: number;
        lng: number;
        type: 'total' | 'edge' | 'partial';
        duration?: string;
        contact?: string;
    };

    var container = document.getElementById('eclipse-map');
    if (!container) throw new Error('Map container not found');

    var polygon = JSON.parse(container.dataset.polygon || '[]');
    var places: MapPlace[] = JSON.parse(container.dataset.places || '[]');

    var map = L.map(container, {
        center: [41.5, -2.5],
        zoom: 7,
        scrollWheelZoom: true,
        zoomControl: true,
    });

    L.Control.Zoom.prototype.options.zoomInTitle = 'Acercar';
    L.Control.Zoom.prototype.options.zoomOutTitle = 'Alejar';

    var tileLayer = L.tileLayer(
        'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
        {
            attribution:
                '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> · <a href="https://carto.com/">CARTO</a>',
            subdomains: 'abcd',
            maxZoom: 19,
        },
    ).addTo(map);

    function swapTiles(theme: string) {
        var url =
            theme === 'light'
                ? 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png'
                : 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png';
        map.removeLayer(tileLayer);
        tileLayer = L.tileLayer(url, {
            attribution:
                '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> · <a href="https://carto.com/">CARTO</a>',
            subdomains: 'abcd',
            maxZoom: 19,
        }).addTo(map);
    }

    var themeWatcher = new MutationObserver(function () {
        var theme = document.documentElement.getAttribute('data-theme') || 'dark';
        swapTiles(theme);
    });
    themeWatcher.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme'],
    });

    // apply initial theme
    var initialTheme = document.documentElement.getAttribute('data-theme') || 'dark';
    if (initialTheme === 'light') swapTiles('light');

    L.polygon(polygon, {
        color: '#00aaff',
        weight: 2,
        opacity: 0.8,
        fillColor: '#00aaff',
        fillOpacity: 0.12,
    }).addTo(map);

    places.forEach(function (p: MapPlace) {
        if (!p.lat || !p.lng) return;

        var dotClass = 'map-marker__dot';
        var labelClass = 'map-marker__label';

        if (p.type === 'edge') {
            dotClass += ' map-marker__dot--edge';
            labelClass += ' map-marker__label--edge';
        } else if (p.type === 'partial') {
            dotClass += ' map-marker__dot--partial';
        } else {
            labelClass += ' map-marker__label--total';
        }

        var html =
            '<span class="' +
            dotClass +
            '"></span><span class="' +
            labelClass +
            '">' +
            p.city +
            '</span>';

        var marker = L.marker([p.lat, p.lng], {
            icon: L.divIcon({
                className: 'map-marker',
                html: html,
                iconSize: [0, 0],
                iconAnchor: [0, 12],
            }),
        }).addTo(map);

        var typeTag =
            p.type === 'total'
                ? 'Total'
                : p.type === 'edge'
                  ? 'Borde'
                  : 'Parcial';

        var popupHtml =
            '<div class="map-marker__popup">' +
            '<span class="map-marker__popup-tag">' +
            typeTag +
            '</span>' +
            '<strong class="map-marker__popup-city">' +
            p.city +
            '</strong>' +
            '<span class="map-marker__popup-region">' +
            p.region +
            '</span>' +
            '<div class="map-marker__popup-meta">' +
            '<span>' +
            p.duration +
            '</span>' +
            '<span>Contacto: ' +
            p.contact +
            '</span>' +
            '</div>' +
            '<a href="/location/' +
            p.slug +
            '" class="map-marker__popup-link">Más info →</a>' +
            '</div>';

        marker.bindPopup(popupHtml, {
            closeButton: false,
            className: 'map-marker__popup-wrap',
            offset: [0, -16],
        });

        var eclipseWindow = window as Window & {
            __eclipsariumMarkers?: L.Marker[];
            __eclipsariumMap?: L.Map;
            __eclipsariumMeta?: WeakMap<
                L.Marker,
                { city: string; region: string }
            >;
        };

        if (!eclipseWindow.__eclipsariumMarkers) {
            eclipseWindow.__eclipsariumMarkers = [];
            eclipseWindow.__eclipsariumMap = map;
            eclipseWindow.__eclipsariumMeta = new WeakMap();
        }
        eclipseWindow.__eclipsariumMeta!.set(marker, {
            city: p.city,
            region: p.region,
        });
        eclipseWindow.__eclipsariumMarkers.push(marker);

        let popupTimeout: ReturnType<typeof setTimeout> | undefined;

        marker.on('mouseover', function () {
            clearTimeout(popupTimeout);
            marker.openPopup();
        });

        marker.on('mouseout', function () {
            popupTimeout = setTimeout(function () {
                marker.closePopup();
            }, 300);
        });

        marker.on('click', function () {
            window.location.href = '/location/' + p.slug;
        });

        marker.on('popupopen', function () {
            var popup = marker.getPopup();
            if (!popup) return;
            var popupEl = popup.getElement();
            if (popupEl && !popupEl.hasAttribute('data-hover')) {
                popupEl.setAttribute('data-hover', '1');
                popupEl.addEventListener('mouseenter', function () {
                    clearTimeout(popupTimeout);
                });
                popupEl.addEventListener('mouseleave', function () {
                    marker.closePopup();
                });
            }
        });
    });
</script>
