---
import { faq, myths } from '../data/faq.json';
---

<section id="preguntas" class="faq section">
    <div class="shell faq__shell">
        <header class="section__header">
            <span class="eyebrow">Aprende</span>
            <h2>Preguntas frecuentes</h2>
            <p class="section__lead">
                Todo lo que siempre quisiste saber sobre eclipses solares, resuelto
                con datos de fuentes oficiales.
            </p>
        </header>

        <div class="faq__block">
            <h3 class="faq__subheading">FAQ</h3>
            <div class="faq__list">
                {
                    faq.map((item) => (
                        <details class="faq__item accordion">
                            <summary class="accordion-head">
                                {item.q}
                                <span class="accordion-arrow" aria-hidden="true"
                                    >→</span
                                >
                            </summary>
                            <div class="accordion-body">
                                <p>{item.a}</p>
                                <cite class="faq__cite"><a href={item.source.url} target="_blank" rel="noopener noreferrer">{item.source.name}</a></cite>
                            </div>
                        </details>
                    ))
                }
            </div>
        </div>

        <div class="faq__block">
            <h3 class="faq__subheading">Mitos y realidades</h3>
            <div class="faq__list">
                {
                    myths.map((item) => (
                        <details class="faq__item accordion">
                            <summary class="accordion-head">
                                {item.myth}
                                <span class="accordion-arrow" aria-hidden="true"
                                    >→</span
                                >
                            </summary>
                            <div class="accordion-body">
                                <p>{item.truth}</p>
                                <cite class="faq__cite"><a href={item.source.url} target="_blank" rel="noopener noreferrer">{item.source.name}</a></cite>
                            </div>
                        </details>
                    ))
                }
            </div>
        </div>

    </div>
</section>

<style>
    .faq__block {
        margin-top: var(--section-y);
    }

    .faq__subheading {
        font-size: var(--step-1);
        font-weight: 600;
        color: var(--bone);
        margin-bottom: 1rem;
    }

    .faq__list {
        display: grid;
        gap: 0.65rem;
    }

    .faq__item {
        border: 1px solid var(--line);
        border-radius: var(--radius-sm);
        background: var(--ink-soft);
        overflow: hidden;
        transition: border-color 0.25s var(--ease);
    }

    .faq__item[open] {
        border-color: var(--space-blue);
    }

    .faq__item .accordion-head {
        font-size: var(--step-0);
        text-transform: none;
        letter-spacing: normal;
        color: var(--bone);
        padding: 1rem 1.4rem;
        font-family: var(--font-body);
        font-weight: 500;
        line-height: 1.4;
    }

    .faq__item[open] .accordion-head {
        color: var(--space-blue);
    }

    .faq__item .accordion-body {
        padding-top: 0.6rem;
    }

    .faq__item .accordion-body p {
        color: var(--bone-dim);
        font-size: var(--step--1);
        line-height: 1.65;
    }

    .faq__cite {
        display: block;
        margin-top: 0.75rem;
        font-size: 0.7rem;
        font-family: var(--font-mono);
        color: var(--muted);
        font-style: normal;
        letter-spacing: 0.05em;
    }

    .faq__cite a {
        color: var(--muted);
        text-decoration: underline;
        text-decoration-color: var(--muted-deep);
        transition: color 0.25s var(--ease);
    }

    .faq__cite a:hover {
        color: var(--space-blue);
    }

    @media (max-width: 560px) {
        .faq__item .accordion-head {
            padding: 0.85rem 1rem;
            font-size: var(--step--1);
        }

        .faq__item .accordion-body {
            padding-inline: 1rem;
        }
    }
</style>
