---
import Layout from '../layouts/Layout.astro';
import EclipseAnimation from '../components/EclipseAnimation.astro';
// import OrbitSimulation from '../components/OrbitSimulation.astro';
import EventInfo from '../components/EventInfo.astro';
import WhereToWatch from '../components/WhereToWatch.astro';
import Countdown from '../components/Countdown.astro';
import PrepChecklist from '../components/PrepChecklist.astro';
import KidsActivities from '../components/KidsActivities.astro';
---

<Layout>
    <header class="topbar">
        <div class="shell topbar__inner">
            <a href="#" class="brand">ECLIPSARIUM<span>·26</span></a>
            <nav class="nav nav--desktop">
                <a href="#cuenta">Cuenta atrás</a>
                <a href="#evento">El evento</a>
                <a href="#donde">Dónde verlo</a>
                <a href="#checklist">Checklist</a>
                <a href="#actividades">Actividades</a>
            </nav>

            <button class="theme-toggle" aria-label="Cambiar tema">
                <svg class="theme-toggle__sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1" x2="12" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/>
                    <line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
                <svg class="theme-toggle__moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
            </button>

            <details class="nav-mobile">
                <summary
                    class="nav-mobile__trigger"
                    aria-label="Abrir navegación"
                >
                    <span class="nav-mobile__icon" aria-hidden="true">
                        <span></span>
                        <span></span>
                        <span></span>
                    </span>
                </summary>
                <nav class="nav-mobile__panel" aria-label="Navegación móvil">
                    <a href="#cuenta">Cuenta atrás</a>
                    <a href="#evento">El evento</a>
                    <a href="#donde">Dónde verlo</a>
                    <a href="#checklist">Checklist</a>
                    <a href="#actividades">Actividades</a>
                </nav>
            </details>
        </div>
    </header>

    <main>
        <section class="hero">
            <div class="shell hero__inner">
                <div class="hero__copy">
                    <span class="kicker">12 · 08 · 2026 — España</span>
                    <h1 class="hero__title">
                        <br /><em>ECLIPSE SOLAR TOTAL</em><br />visible desde
                        España
                    </h1>
                    <p class="hero__sub">
                        Cruzará el norte de la península por primera vez en más
                        de un siglo. Esto es lo que vas a ver, y dónde.
                    </p>
                    <a href="#donde" class="btn hero__cta">
                        Encuentra tu lugar
                        <span aria-hidden="true">↓</span>
                    </a>
                </div>

                <div class="hero__visual">
                    <EclipseAnimation />
                    <!-- <OrbitSimulation /> -->
                </div>
            </div>

            <div class="hero__marquee" aria-hidden="true">
                <div class="marquee__track">
                    <span>TOTALIDAD · 1M 49S</span><span>✦</span>
                    <span>CORONA VISIBLE</span><span>✦</span>
                    <span>ANILLO DE DIAMANTE</span><span>✦</span>
                    <span>SOMBRA DE LA LUNA</span><span>✦</span>
                    <span>TOTALIDAD · 1M 49S</span><span>✦</span>
                    <span>CORONA VISIBLE</span><span>✦</span>
                    <span>ANILLO DE DIAMANTE</span><span>✦</span>
                    <span>SOMBRA DE LA LUNA</span><span>✦</span>
                </div>
            </div>
        </section>
        <Countdown />
        <EventInfo />
        <WhereToWatch />
        <PrepChecklist />
        <KidsActivities />
    </main>

    <footer class="foot">
        <div class="shell foot__inner">
            <p class="foot__warn">
                <strong>⚠ Nunca mires al Sol sin protección certificada.</strong
                >
                Usa gafas de eclipse con norma <span>ISO&nbsp;12312-2</span>.
                Las gafas de sol normales no protegen tu vista.
            </p>
            <p class="foot__sig">
                ECLIPSARIUM — proyecto divulgativo · <a
                    class="foot__link"
                    href="https://github.com/Yevestevez/">Edu Yeves</a
                >
            </p>
        </div>
    </footer>
</Layout>

<script>
    const mobileMenu = document.querySelector('.nav-mobile');
    const mobileLinks = document.querySelectorAll('.nav-mobile__panel a');

    mobileLinks.forEach((link) => {
        link.addEventListener('click', () => {
            if (mobileMenu instanceof HTMLDetailsElement) {
                mobileMenu.open = false;
            }
        });
    });

    // Theme toggle
    const toggle = document.querySelector('.theme-toggle');
    if (toggle) {
        toggle.addEventListener('click', () => {
            const html = document.documentElement;
            const isLight = html.getAttribute('data-theme') === 'light';
            if (isLight) {
                html.removeAttribute('data-theme');
                localStorage.setItem('theme', 'dark');
            } else {
                html.setAttribute('data-theme', 'light');
                localStorage.setItem('theme', 'light');
            }
        });
    }
</script>

<style>
    /* --- Topbar --- */
    .topbar {
        position: sticky;
        top: 0;
        z-index: 100;
        padding-block: 2rem;
        backdrop-filter: blur(10px);
        background: linear-gradient(var(--void), transparent);
        border-bottom: 1px solid var(--space-blue);
    }

    .topbar__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
    }

    .brand {
        font-family: var(--font-mono);
        font-weight: 700;
        letter-spacing: 0.2em;
        font-size: 0.9rem;
    }

    .brand span {
        color: var(--space-blue);
    }

    .nav {
        display: flex;
        gap: clamp(1rem, 3vw, 2.4rem);
        font-family: var(--font-mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--muted);
    }

    .nav a {
        transition: color 0.3s var(--ease);
    }

    .nav a:hover {
        color: var(--space-blue);
    }

    .nav-mobile {
        display: none;
    }

    .nav-mobile__trigger {
        list-style: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.6rem;
        height: 2.3rem;
        padding: 0;
        --cut: 12px;
        border-radius: 0.2rem;
        border: none;
        background: var(--ink-soft);
        clip-path: polygon(
            0 0,
            100% 0,
            100% 100%,
            var(--cut) 100%,
            0 calc(100% - var(--cut))
        );
        transition: background-color 0.25s var(--ease);
        user-select: none;
    }

    .nav-mobile__trigger:hover {
        background: var(--hover-bg-blue);
    }

    .nav-mobile__icon {
        display: inline-flex;
        flex-direction: column;
        gap: 0.28rem;
    }

    .nav-mobile__icon span {
        display: block;
        width: 1.05rem;
        height: 1px;
        background: var(--space-blue);
        transform-origin: center;
        transition:
            transform 0.25s var(--ease),
            opacity 0.2s var(--ease);
    }

    .nav-mobile[open] .nav-mobile__trigger {
        background: var(--hover-bg-blue);
    }

    .nav-mobile[open] .nav-mobile__icon span:nth-child(1) {
        transform: translateY(0.38rem) rotate(45deg);
    }

    .nav-mobile[open] .nav-mobile__icon span:nth-child(2) {
        opacity: 0;
    }

    .nav-mobile[open] .nav-mobile__icon span:nth-child(3) {
        transform: translateY(-0.38rem) rotate(-45deg);
    }

    .nav-mobile__trigger::-webkit-details-marker {
        display: none;
    }

    .nav-mobile__panel {
        position: absolute;
        top: calc(100% + 0.6rem);
        right: 0;
        min-width: 190px;
        display: grid;
        gap: 0.2rem;
        padding: 0.5rem;
        border: 1px solid var(--line);
        border-radius: 0.2rem;
            background: var(--overlay);
        backdrop-filter: blur(8px);
    }

    .nav-mobile__panel a {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--bone-dim);
        padding: 0.55rem 0.6rem;
        border-radius: 0.2rem;
        transition:
            color 0.25s var(--ease),
            background-color 0.25s var(--ease);
    }

    .nav-mobile__panel a:hover {
        color: var(--hover-color);
        background: var(--hover-bg-blue);
    }

    .nav-mobile:not([open]) .nav-mobile__panel {
        display: none;
    }

    /* --- Theme toggle --- */
    .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.2rem;
        height: 2.2rem;
        padding: 0;
        border: 1px solid var(--line);
        border-radius: var(--radius-pill);
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        transition: color 0.3s var(--ease), border-color 0.3s var(--ease), background 0.3s var(--ease);
        margin-left: auto;
    }

    .theme-toggle:hover {
        color: var(--space-blue);
        border-color: var(--space-blue);
        background: var(--hover-bg-blue);
    }

    .theme-toggle svg {
        display: block;
    }

    :root .theme-toggle__moon,
    [data-theme="dark"] .theme-toggle__moon {
        display: block;
    }

    :root .theme-toggle__sun,
    [data-theme="dark"] .theme-toggle__sun {
        display: none;
    }

    [data-theme="light"] .theme-toggle__moon {
        display: none;
    }

    [data-theme="light"] .theme-toggle__sun {
        display: block;
    }

    @media (max-width: 560px) {
        .nav--desktop {
            display: none;
        }

        .nav-mobile {
            display: block;
        }

        .topbar {
            padding-block: 1rem;
        }
    }

    /* --- Hero --- */
    .hero {
        position: relative;
        z-index: 1;
        padding-top: clamp(1rem, 3vh, 2.5rem);
    }

    .hero__inner {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        align-items: center;
        gap: clamp(2rem, 5vw, 4rem);
        gap: 0;
        min-height: 68vh;
    }

    .hero__title {
        font-size: var(--step-3);
        font-weight: 700;
        margin-top: -2rem;
    }

    .hero__title em {
        font-style: italic;
        color: var(--space-blue);
    }

    .hero__sub {
        margin-top: 1.8rem;
        max-width: 42ch;
        color: var(--bone-dim);
        font-size: var(--step-0);
        font-weight: 300;
        line-height: 1.5;
    }

    .hero__cta {
        margin-top: 2.4rem;
    }

    .hero__cta:hover {
        gap: 1.1rem;
    }

    .hero__visual {
        display: grid;
        place-items: center;
    }

    @media (max-width: 860px) {
        .hero__inner {
            grid-template-columns: 1fr;
            min-height: auto;
            gap: 1rem;
        }
        .hero__visual {
            order: -1;
            margin-bottom: 1rem;
        }
    }

    /* --- Marquee --- */
    .hero__marquee {
        margin-top: clamp(1.5rem, 4vh, 3rem);
        border-block: 1px solid var(--line);
        padding-block: 1.1rem;
        overflow: hidden;
        white-space: nowrap;
    }

    .marquee__track {
        display: inline-flex;
        align-items: center;
        gap: 2.4rem;
        font-family: var(--font-accent);
        font-weight: 200;
        text-transform: uppercase;
        font-size: var(--step-1);
        color: var(--bone-dim);
        animation: marquee 32s linear infinite;
    }

    .marquee__track span:nth-child(even) {
        color: var(--space-blue);
        font-style: normal;
        font-size: 0.6em;
    }

    @keyframes marquee {
        to {
            transform: translateX(-50%);
        }
    }

    /* --- Footer --- */
    .foot {
        position: relative;
        z-index: 1;
        border-top: 1px solid var(--line);
        padding-block: clamp(3rem, 7vw, 5rem);
    }

    .foot__inner {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 2rem;
        align-items: end;
    }

    .foot__warn {
        max-width: 52ch;
        color: var(--bone-dim);
        font-size: var(--step--1);
        line-height: 1.7;
    }

    .foot__warn strong {
        color: var(--space-blue);
        font-weight: 600;
    }

    .foot__warn span {
        font-family: var(--font-mono);
        color: var(--bone);
    }

    .foot__sig {
        font-family: var(--font-mono);
        font-size: 0.66rem;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: var(--muted-deep);
    }
    .foot__sig .foot__link:hover {
        color: var(--space-blue);
    }
</style>
