---
import data from '../data/locations.json';
import EclipseMap from './EclipseMap.astro';

const parseDur = (d: string) => {
    if (d.includes('%')) return parseFloat(d.replace(',', '.'));
    const m = d.match(/(\d+)m\s*(\d+)s/);
    return m ? +m[1] * 60 + +m[2] : parseInt(d) || 0;
};

const order = { total: 0, edge: 1, partial: 2 };
const sorted = [...data.places].sort((a, b) => {
    return order[a.type as keyof typeof order] - order[b.type as keyof typeof order] || parseDur(b.duration) - parseDur(a.duration);
});
---

<section id="donde" class="where">
    <div class="shell">
        <header class="where__head">
            <span class="eyebrow">Dónde verlo</span>
            <h2 class="where__title">La franja de <em>totalidad</em></h2>
            <p class="where__lead">
                Solo dentro de una estrecha banda que cruza el norte peninsular
                el Sol desaparecerá por completo. Fuera de ella, el eclipse será
                parcial.
            </p>
        </header>

        <EclipseMap />

        <div class="search">
            <svg class="search__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="search" id="location-search" class="search__input" placeholder="Buscar localidad…" aria-label="Filtrar localidades por nombre o región">
        </div>

        <ul class="places">
            {
                sorted.map((p) => {
                    const tag =
                        p.type === 'total'
                            ? 'Total'
                            : p.type === 'edge'
                              ? 'Borde'
                              : 'Parcial';
                    return (
                        <li
                            data-city={p.city}
                            data-region={p.region}
                            data-type={p.type}
                            class:list={[
                                'place',
                                `place--${p.type}`,
                            ]}
                        >
                            <a href={`/location/${p.slug}`} class="place__link">
                                <div class="place__tag">
                                    {tag}
                                </div>
                                <h3 class="place__city">{p.city}</h3>
                                <p class="place__region">{p.region}</p>
                                <div class="place__meta">
                                    <span class="place__dur">{p.duration}</span>
                                    <span class="place__time">
                                        Contacto · {p.contact}
                                    </span>
                                </div>
                            </a>
                        </li>
                    );
                })
            }
        </ul>
    </div>
</section>

<script>
    var searchInput = document.getElementById('location-search');
    if (searchInput) {
        var placeItems = document.querySelectorAll('.place');

        searchInput.addEventListener('input', function () {
            var q = this.value.trim().toLowerCase();

            placeItems.forEach(function (el) {
                var city = (el.getAttribute('data-city') || '').toLowerCase();
                var region = (el.getAttribute('data-region') || '').toLowerCase();
                var type = (el.getAttribute('data-type') || '').toLowerCase();
                var match =
                    !q ||
                    city.indexOf(q) !== -1 ||
                    region.indexOf(q) !== -1 ||
                    type.indexOf(q) !== -1;
                el.classList.toggle('place--hidden', !match);
            });

            var markers = window.__eclipsariumMarkers;
            var meta = window.__eclipsariumMeta;
            var map = window.__eclipsariumMap;
            if (markers && meta && map) {
                markers.forEach(function (m) {
                    var d = meta.get(m);
                    if (!d) return;
                    var city = (d.city || '').toLowerCase();
                    var region = (d.region || '').toLowerCase();
                    var match = !q || city.indexOf(q) !== -1 || region.indexOf(q) !== -1;
                    if (match) {
                        map.addLayer(m);
                    } else {
                        map.removeLayer(m);
                    }
                });
            }
        });
    }
</script>

<style>
    .where {
        padding-block: var(--section-y);
        position: relative;
        z-index: 1;
    }

    .search {
        position: relative;
        margin-top: 2rem;
        max-width: 22rem;
    }

    .search__icon {
        position: absolute;
        left: 0.9rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        pointer-events: none;
    }

    .search__input {
        all: unset;
        box-sizing: border-box;
        display: block;
        width: 100%;
        padding: 0.75rem 0.9rem 0.75rem 2.6rem;
        font-family: var(--font-mono);
        font-size: var(--step-0);
        color: var(--bone);
        background: var(--ink-soft);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease);
    }

    .search__input::placeholder {
        color: var(--muted-deep);
    }

    .search__input:focus {
        border-color: var(--space-blue);
        box-shadow: 0 0 0 1px var(--space-blue);
        outline: none;
    }

    .place--hidden {
        display: none;
    }

    .where__head {
        max-width: 52ch;
    }

    .where__title {
        font-size: var(--step-2);
        margin-top: 1.2rem;
    }

    .where__title em {
        font-style: italic;
        color: var(--space-blue);
    }

    .where__lead {
        margin-top: 1.4rem;
        color: var(--bone-dim);
        font-weight: 300;
        max-width: 46ch;
    }

    .places {
        list-style: none;
        margin: clamp(3rem, 7vw, 5rem) 0 0;
        padding: 0;
        display: grid;
        gap: 1px;
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 250px), 1fr));
        background: var(--line);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        overflow: hidden;
    }

    .place {
        background: var(--ink);
        transition: background 0.4s var(--ease);
    }

    .place__link {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        padding: 1.8rem 1.6rem 1.6rem;
        text-decoration: none;
        color: inherit;
        transition: background 0.4s var(--ease);
    }

    .place__link:hover {
        background: var(--ink-soft);
    }

    .place__tag {
        align-self: flex-start;
        font-family: var(--font-mono);
        font-size: 0.62rem;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        padding: 0.3rem 0.6rem;
        border: none;
        --cut: 10px;
        border-radius: 0.2rem;
        background: var(--ink-soft);
        clip-path: polygon(
            0 0,
            100% 0,
            100% 100%,
            var(--cut) 100%,
            0 calc(100% - var(--cut))
        );
        color: var(--muted);
        margin-bottom: 0.8rem;
    }

    .place--total .place__tag {
        color: var(--void);
        background: var(--space-blue);
        border-color: var(--space-blue);
    }

    .place--edge .place__tag {
        color: var(--bone);
        background: var(--edge-blue);
        border-color: var(--edge-blue);
    }

    .place__city {
        font-size: clamp(1.6rem, 3vw, 2.1rem);
    }

    .place__region {
        color: var(--muted);
        font-size: var(--step--1);
        margin: 0;
    }

    .place__meta {
        margin-top: 1.2rem;
        padding-top: 1rem;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        font-family: var(--font-mono);
        font-size: 0.74rem;
    }

    .place__dur {
        color: var(--muted);
    }

    .place--total .place__dur {
        color: var(--space-blue);
    }

    .place--edge .place__dur {
        color: var(--edge-blue);
    }

    .place__time {
        color: var(--muted);
        letter-spacing: 0.05em;
    }
</style>
